# --- Local LLM (Ollama) ---
# Start Ollama: https://ollama.com  →  ollama pull llama3.1
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2

# --- TTS Provider ---
# Options: edge-tts | windows-sapi | stub
# edge-tts requires: pip install edge-tts
# windows-sapi uses built-in Windows Speech API (WAV output, lower quality)
# stub runs without audio (useful for testing the pipeline)
TTS_PROVIDER=edge-tts
TTS_VOICE=en-US-AndrewNeural

# --- Server ---
SCENE_PORT=3000
